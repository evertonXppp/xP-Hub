--// INPUT
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- Menu key listening
    if ListeningForMenuKey then
        local key = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
        Settings.MenuKey = key
        local name = tostring(key):gsub("Enum%.UserInputType%.", ""):gsub("Enum%.KeyCode%.", "")
        UI.MenuKeyLbl.Text = "Menu Key: " .. name
        UI.MenuKeyBtn.Text = "Change"
        UI.MenuKeyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        ListeningForMenuKey = false
        return
    end

    -- Toggle menu visibility
    local matchMenu = false
    if Settings.MenuKey.EnumType == Enum.KeyCode then
        matchMenu = input.KeyCode == Settings.MenuKey
    elseif Settings.MenuKey.EnumType == Enum.UserInputType then
        matchMenu = input.UserInputType == Settings.MenuKey
    end
    if matchMenu then
        if UI.MainFrame then
            MenuVisible = not MenuVisible
            UI.MainFrame.Visible = MenuVisible
        end
        return
    end

    -- Aim key listening
    if ListeningForKey then
        local key = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
        Settings.AimKey = key
        local name = tostring(key):gsub("Enum%.UserInputType%.", ""):gsub("Enum%.KeyCode%.", "")
        UI.KeyLbl.Text = "Aim Key: " .. name
        UI.KeyBtn.Text = "Change"
        UI.KeyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        ListeningForKey = false
        return
    end

    local matchAim = false
    if Settings.AimKey.EnumType == Enum.KeyCode then
        matchAim = input.KeyCode == Settings.AimKey
    elseif Settings.AimKey.EnumType == Enum.UserInputType then
        matchAim = input.UserInputType == Settings.AimKey
    end
    if matchAim then
        HoldingAim = true
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    local matchAim = false
    if Settings.AimKey.EnumType == Enum.KeyCode then
        matchAim = input.KeyCode == Settings.AimKey
    elseif Settings.AimKey.EnumType == Enum.UserInputType then
        matchAim = input.UserInputType == Settings.AimKey
    end
    if matchAim then
        HoldingAim = false
        CurrentTarget = nil
    end
end)

--// RENDER LOOP
RunService.RenderStepped:Connect(function()
    if not ScriptActive then return end
    if not Camera or not Camera.Parent then
        Camera = Workspace:FindFirstChild("CustomCamera")
        if not Camera or not Camera:IsA("Camera") then
            Camera = Workspace.CurrentCamera
        end
    end
    if not Camera then return end

    -- FOV Circle
    if Settings.ESPDrawFOV then
        FOVDraw.Position = Camera.ViewportSize / 2
        FOVDraw.Radius = Settings.FOV
        FOVDraw.Visible = true
    else
        FOVDraw.Visible = false
    end

    -- AIMBOT
    if Settings.AimEnabled and HoldingAim then
        local valid = false

        if CurrentTarget then
            local char = CurrentTarget.Player.Character
            local part = char and GetAimPart(char)
            if part and IsAlive(char) and IsTargetValid(CurrentTarget.Player) then
                local aimPos = GetAimPosition(part)
                local pos, onScreen = Camera:WorldToViewportPoint(aimPos)
                if onScreen then
                    local sd = (Vector2.new(pos.X, pos.Y) - Camera.ViewportSize / 2).Magnitude
                    if sd <= Settings.FOV and IsVisible(char, aimPos) then
                        valid = true
                        CurrentTarget.Part = part
                        CurrentTarget.Position = pos
                        CurrentTarget.Distance = (part.Position - Camera.CFrame.Position).Magnitude
                    end
                end
            end
        end

        if not valid then
            CurrentTarget = Settings.AutoSwitch and GetClosestPlayer() or nil
        end

        if CurrentTarget then
            local part = CurrentTarget.Part
            local aimPos = GetAimPosition(part)

            if Settings.OverrideCam then
                Camera.CameraType = Enum.CameraType.Scriptable
            end

            local targetCF = CFrame.new(Camera.CFrame.Position, aimPos)
            if Settings.Smoothness >= 0.99 then
                Camera.CFrame = targetCF
            else
                Camera.CFrame = Camera.CFrame:Lerp(targetCF, Settings.Smoothness)
            end

            local pos, onScreen = Camera:WorldToViewportPoint(aimPos)
            if onScreen then
                TargetDraw.Position = Vector2.new(pos.X, pos.Y)
                TargetDraw.Radius = math.clamp(500 / pos.Z, 5, 30)
                TargetDraw.Visible = true
            else
                TargetDraw.Visible = false
            end
        else
            TargetDraw.Visible = false
        end
    else
        CurrentTarget = nil
        TargetDraw.Visible = false
    end

    -- ESP
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local data = GetESP(player)
        data.Box.Visible = false
        data.Outline.Visible = false
        data.Tracer.Visible = false
        data.Info.Visible = false
        data.HeartBg.Visible = false
        data.HeartFill.Visible = false
        for _, line in ipairs(data.SkeletonLines) do
            line.Visible = false
        end

        if not Settings.ESPEnabled then continue end

        local char = player.Character
        if not char or not IsAlive(char) or not IsTargetValid(player) then continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not root or not head then continue end

        local dist = (root.Position - Camera.CFrame.Position).Magnitude
        if dist > Settings.ESPMaxDist then continue end

        local rootPos, rootOnScreen = Camera:WorldToViewportPoint(root.Position)
        local headPos, headOnScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        if not rootOnScreen or not headOnScreen then continue end

        local screenRoot = Vector2.new(rootPos.X, rootPos.Y)
        local screenHead = Vector2.new(headPos.X, headPos.Y)
        local hp, maxHp = GetHealth(char)
        local locked = CurrentTarget and CurrentTarget.Player == player

        -- Cor base
        local color = locked and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 100)

        -- TRACER
        if Settings.ESPTracers then
            data.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            data.Tracer.To = screenRoot
            data.Tracer.Color = locked and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(255, 255, 255)
            data.Tracer.Transparency = locked and 1 or 0.6
            data.Tracer.Visible = true
        end

        -- BOX + OUTLINE (tamanho baseado na distância cabeça-root, igual xP Hub.lua)
        if Settings.ESPBoxes then
            local height = math.abs(headPos.Y - rootPos.Y) * 2 * Settings.BoxSizeMultiplier
            local width = height / 2
            local posX = screenRoot.X - width / 2
            local posY = screenRoot.Y - (height / 2) + 10

            data.Outline.Size = Vector2.new(width + 2, height + 2)
            data.Outline.Position = Vector2.new(posX - 1, posY - 1)
            data.Outline.Thickness = 1
            data.Outline.Color = Color3.fromRGB(0, 0, 0)
            data.Outline.Visible = true

            data.Box.Size = Vector2.new(width, height)
            data.Box.Position = Vector2.new(posX, posY)
            data.Box.Thickness = 1
            data.Box.Color = color
            data.Box.Visible = true

            -- INFO (nome, HP, distância)
            if Settings.ESPInfo then
                data.Info.Position = Vector2.new(screenRoot.X, posY - 20)
                data.Info.Text = player.Name .. "\nHP:" .. hp .. "/" .. maxHp .. " | " .. math.floor(dist) .. "s"
                data.Info.Color = locked and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(255, 255, 255)
                data.Info.Visible = true
            end

            -- HEART BAR (mesma altura da box)
            if Settings.ESPHeartBar then
                local lineX = posX + width + 6

                data.HeartBg.From = Vector2.new(lineX, posY)
                data.HeartBg.To = Vector2.new(lineX, posY + height)
                data.HeartBg.Thickness = 3
                data.HeartBg.Color = Color3.fromRGB(0, 0, 0)
                data.HeartBg.Visible = true

                local healthPercent = hp / maxHp
                local healthColor
                if healthPercent > 0.7 then
                    healthColor = Color3.fromRGB(0, 255, 0)
                elseif healthPercent > 0.3 then
                    healthColor = Color3.fromRGB(255, 200, 0)
                else
                    healthColor = Color3.fromRGB(255, 50, 50)
                end

                local fillHeight = height * healthPercent
                data.HeartFill.From = Vector2.new(lineX, posY + height - fillHeight)
                data.HeartFill.To = Vector2.new(lineX, posY + height)
                data.HeartFill.Thickness = 3
                data.HeartFill.Color = healthColor
                data.HeartFill.Visible = true
            end
        end

        -- SKELETON
        if Settings.ESPSkeleton then
            local skeletonColor = locked and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(255, 255, 255)
            UpdateSkeletonLines(data, char, skeletonColor)
        end
    end
end)

--// CLEANUP
Players.PlayerRemoving:Connect(function(player)
    RemoveESP(player)
    if CurrentTarget and CurrentTarget.Player == player then
        CurrentTarget = nil
    end
end)

