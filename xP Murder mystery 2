    end)
    if success and data then
        roles = data
        playerData = data
        for nome, info in pairs(data) do
            if info.Role == "Murderer" then Murder = nome
            elseif info.Role == "Sheriff" then Sheriff = nome
            elseif info.Role == "Hero" then Hero = nome
            end
        end
        CreateHighlight()
        UpdateHighlights()
    end
end)

