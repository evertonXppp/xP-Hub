local function sendNotification(title, text)
    game.StarterGui:SetCore("SendNotification", { Title = title, Text = text, Duration = 2 })
end

local function updateGameSettings()
    local settings = ReplicatedStorage:FindFirstChild("Settings")
    if not settings then return end

    if Features.NoCooldown.enabled then
        local cooldowns = settings:FindFirstChild("Cooldowns")
        if cooldowns then
            for _, cd in pairs(cooldowns:GetChildren()) do
                if cd:IsA("NumberValue") then cd.Value = 0 end
            end
        end
        local multipliers = settings:FindFirstChild("Multipliers")
        if multipliers and multipliers:FindFirstChild("MeleeSpeed") then
            multipliers.MeleeSpeed.Value = 1000
        end
    else
        local cooldowns = settings:FindFirstChild("Cooldowns")
        if cooldowns then
            if cooldowns:FindFirstChild("Dash") then cooldowns.Dash.Value = 100 end
            if cooldowns:FindFirstChild("Evasive") then cooldowns.Evasive.Value = 100 end
            if cooldowns:FindFirstChild("WallCombo") then cooldowns.WallCombo.Value = 0 end
            if cooldowns:FindFirstChild("Melee") then cooldowns.Melee.Value = 100 end
        end
        local multipliers = settings:FindFirstChild("Multipliers")
        if multipliers and multipliers:FindFirstChild("MeleeSpeed") then
            multipliers.MeleeSpeed.Value = 100
        end
    end

    local toggles = settings:FindFirstChild("Toggles")
    if toggles then
        if Features.NoStun.enabled then
            if toggles:FindFirstChild("DisableHitStun") then toggles.DisableHitStun.Value = true end
            if toggles:FindFirstChild("NoStunOnMiss") then toggles.NoStunOnMiss.Value = true end
        else
            if toggles:FindFirstChild("DisableHitStun") then toggles.DisableHitStun.Value = false end
            if toggles:FindFirstChild("NoStunOnMiss") then toggles.NoStunOnMiss.Value = false end
        end
    end

    local multipliers = settings:FindFirstChild("Multipliers")
    if multipliers then
        if Features.InfiniteUltimate.enabled then
            if multipliers:FindFirstChild("UltimateTimer") then multipliers.UltimateTimer.Value = 1e9 end
            if multipliers:FindFirstChild("UltimateDamage") then multipliers.UltimateDamage.Value = 1e9 end
            if toggles and toggles:FindFirstChild("InstantTransformation") then toggles.InstantTransformation.Value = true end
        else
            if multipliers:FindFirstChild("UltimateTimer") then multipliers.UltimateTimer.Value = 100 end
            if multipliers:FindFirstChild("UltimateDamage") then multipliers.UltimateDamage.Value = 100 end
            if toggles and toggles:FindFirstChild("InstantTransformation") then toggles.InstantTransformation.Value = false end
        end
    end
end

local function getCurrentCharacter()
    local data = LocalPlayer:FindFirstChild("Data")
    if data and data:FindFirstChild("Character") then return data.Character.Value end
    return nil
end

local function triggerDash()
    if not Features.KillAura.enabled then return end
    local cfg = Features.KillAura.config
    if tick() - lastDash < cfg.DashInterval then return end
    lastDash = tick()

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local dashRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Character") and ReplicatedStorage.Remotes.Character:FindFirstChild("Dash")
    if dashRemote then
        pcall(function() dashRemote:FireServer(hrp.CFrame, "L", hrp.CFrame.LookVector, nil, tick()) end)
    end
end

local function sendKillAura()
    if not Features.KillAura.enabled then return end
    local cfg = Features.KillAura.config

    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    triggerDash()

    local charName = getCurrentCharacter()
    if not charName then return end

    local wallCombo = ReplicatedStorage:FindFirstChild("Characters") and ReplicatedStorage.Characters:FindFirstChild(charName) and ReplicatedStorage.Characters[charName]:FindFirstChild("WallCombo")
    if not wallCombo then return end

    local abilityRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Abilities") and ReplicatedStorage.Remotes.Abilities:FindFirstChild("Ability")
    local combatRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Combat") and ReplicatedStorage.Remotes.Combat:FindFirstChild("Action")
    if not abilityRemote or not combatRemote then return end

    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if targetPlayer == LocalPlayer then continue end
        if not targetPlayer.Character then continue end

        local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetHRP then continue end

        if cfg.IgnoreFriends and LocalPlayer:IsFriendsWith(targetPlayer.UserId) then continue end

        local targetHumanoid = targetPlayer.Character:FindFirstChild("Humanoid")
        if not targetHumanoid then continue end
        if targetHumanoid.Health <= cfg.HealthLimit then continue end

        if (hrp.Position - targetHRP.Position).Magnitude > cfg.MaxDistance then continue end

        pcall(function()
            abilityRemote:FireServer(wallCombo, cfg.Damage, {}, targetHRP.Position)
        end)

        local combatArgs = {
            wallCombo, charName .. ":WallCombo", 2, cfg.Damage,
            {
                HitboxCFrames = { targetHRP.CFrame, targetHRP.CFrame },
                BestHitCharacter = targetPlayer.Character,
                HitCharacters = { targetPlayer.Character },
                Ignore = {}, DeathInfo = {}, BlockedCharacters = {},
                HitInfo = { IsFacing = false, IsInFront = true },
                ServerTime = os.time(),
                Actions = {
                    ActionNumber1 = {
                        [targetPlayer.Name] = {
                            StartCFrameStr = tostring(hrp.CFrame),
                            Local = true, Collision = false, Animation = "Punch1Hit",
                            Preset = "Punch", Velocity = Vector3.zero,
                            FromPosition = targetHRP.Position, Seed = math.random(1, 999999)
                        }
                    }
                },
                FromCFrame = targetHRP.CFrame
            },
            "Action150", 0
        }
        pcall(function() combatRemote:FireServer(unpack(combatArgs)) end)
    end
end

local function tpwalkUpdate()
    if not Features.TPWalk.enabled then return end

    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end

    local moveDir = humanoid.MoveDirection
    if moveDir.Magnitude > 0 then
        hrp.CFrame = hrp.CFrame + (moveDir * Features.TPWalk.config.Speed)
    end
end

local function applyXRay()
    local transparency = Features.XRay.enabled and Features.XRay.config.transparency or 0
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local char = LocalPlayer.Character
            local isCharacterPart = char and (v:IsDescendantOf(char) or (v.Parent and v.Parent:IsDescendantOf(char)))
            if not isCharacterPart then
                v.LocalTransparencyModifier = transparency
            end
        end
    end
end

local function onNewPart(part)
    if not part:IsA("BasePart") then return end
    local char = LocalPlayer.Character
    local isCharacterPart = char and (part:IsDescendantOf(char) or (part.Parent and part.Parent:IsDescendantOf(char)))
    if not isCharacterPart then
        part.LocalTransparencyModifier = Features.XRay.enabled and Features.XRay.config.transparency or 0
    end
end

local function startXRay()
    if xrayConnection then xrayConnection:Disconnect() end
    applyXRay()
    xrayConnection = workspace.DescendantAdded:Connect(onNewPart)
end

local function stopXRay()
    if xrayConnection then xrayConnection:Disconnect(); xrayConnection = nil end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local char = LocalPlayer.Character
            local isCharacterPart = char and (v:IsDescendantOf(char) or (v.Parent and v.Parent:IsDescendantOf(char)))
            if not isCharacterPart then
                v.LocalTransparencyModifier = 0
            end
        end
    end
end

local function spawnGrayPlatform()
    local ponto1 = Vector3.new(33, -9, 824)
    local ponto2 = Vector3.new(1100, -9, -460)
    local centroX = (ponto1.X + ponto2.X) / 2
    local centroZ = (ponto1.Z + ponto2.Z) / 2
    local tamanhoX = math.abs(ponto2.X - ponto1.X)
    local tamanhoZ = math.abs(ponto2.Z - ponto1.Z)
    local tamanhoY = 1

    local oldPart = workspace:FindFirstChild("SpawnPlacePlatform")
    if oldPart then oldPart:Destroy() end

    local parte = Instance.new("Part")
    parte.Name = "SpawnPlacePlatform"
    parte.Size = Vector3.new(tamanhoX, tamanhoY, tamanhoZ)
    parte.CFrame = CFrame.new(centroX, ponto1.Y, centroZ)
    parte.Anchored = true
    parte.BrickColor = BrickColor.new("Medium stone grey")
    parte.Material = Enum.Material.SmoothPlastic
    parte.Parent = workspace

    sendNotification("Spawn Place", "Plataforma cinza criada no mapa!")
end

-- ============================================================
-- GERENCIADOR DE TOGGLES
-- ============================================================
local function toggleFeature(featureName)
    local feat = Features[featureName]
    if not feat then return end
    feat.enabled = not feat.enabled

    -- Atualiza o toggle visual
    local toggleObj = ToggleObjects[featureName]
    if toggleObj then
        toggleObj:SetValue(feat.enabled)
    end

    -- Ativa/desativa a feature
    if featureName == "NoCooldown" or featureName == "NoStun" or featureName == "InfiniteUltimate" then
        updateGameSettings()
    elseif featureName == "KillAura" then
        if feat.enabled then
            if not killAuraConn then killAuraConn = RunService.Heartbeat:Connect(sendKillAura) end
        else
            if killAuraConn then killAuraConn:Disconnect(); killAuraConn = nil end
        end
    elseif featureName == "TPWalk" then
        if feat.enabled then
            if not tpwalkConn then tpwalkConn = RunService.Heartbeat:Connect(tpwalkUpdate) end
        else
            if tpwalkConn then tpwalkConn:Disconnect(); tpwalkConn = nil end
        end
    elseif featureName == "XRay" then
        if feat.enabled then startXRay() else stopXRay() end
    end

    sendNotification(featureName, feat.enabled and "Ativado" or "Desativado")
end

